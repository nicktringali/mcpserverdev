# Optional API keys
OPENAI_API_KEY=
TAVILY_API_KEY=

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://redis:6379/0

# Postgres (optional)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mcp
POSTGRES_USER=mcp
POSTGRES_PASSWORD=changeme

# MCP Server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
SERVER_NAME=mcp-supercharger
TRANSPORT=sse
MCP_TOKEN=

# Feature Flags
ENABLE_TOOLS=1
ENABLE_VECTOR=1
ENABLE_EXEC=0
ENABLE_TESTS=0
ENABLE_LINT=0

# Workspace mount inside container
WORKSPACE_DIR=/workspace
